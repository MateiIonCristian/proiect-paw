@model IEnumerable<Platforma.Models.Recenzie>
@{ ViewData["Title"] = "Acasă"; }
<header class="py-5 bg-primary text-white text-center shadow rounded-3 mb-5">
    <div class="container py-4">
        <h1 class="display-4 fw-bold">Găsește firme de încredere</h1>
        <p class="lead">Vezi ce spun alți clienți înainte să apelezi la servicii.</p>
        <div class="row justify-content-center mt-4">
            <div class="col-md-7">
                <form asp-controller="Firme" asp-action="Index" method="get">
                    <div class="input-group mb-3 shadow">
                        <input type="text" class="form-control form-control-lg" placeholder="Caută o firmă...">
                        <button class="btn btn-dark btn-lg">Caută</button>
                    </div>
                </form>
            </div>
        </div>
        <div class="mt-4">
            <span class="badge bg-light text-dark px-3 py-2">
                <i class="fas fa-building me-1"></i> Avem deja <strong>@ViewBag.TotalFirme</strong> firme înscrise!
            </span>
        </div>
    </div>
</header>
<div class="row mb-5">
    <div class="col-12">
        <h3 class="fw-bold mb-4 text-center">Ultimele Recenzii</h3>
        <div class="row g-4">
            @foreach (var r in Model) {
                <div class="col-md-4">
                    <div class="card shadow-sm h-100 border-0 hover-shadow transition">
                        <div class="card-body">
                            <h5 class="fw-bold text-info">@r.Firma?.Nume</h5>
                            <div class="text-warning mb-2">
                                @for(int i=0; i<r.Nota; i++) { <i class="fas fa-star"></i> }
                                @for(int i=r.Nota; i<5; i++) { <i class="far fa-star text-muted opacity-25"></i> }
                                <span class="text-muted small ms-2">(@r.Nota/5)</span>
                            </div>
                            <p class="card-text text-muted">"@r.Comentariu"</p>
                        </div>
                        <div class="card-footer bg-transparent border-0 text-end">
                            <small class="text-muted">@r.DataPublicarii.ToString("dd.MM.yyyy")</small>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>