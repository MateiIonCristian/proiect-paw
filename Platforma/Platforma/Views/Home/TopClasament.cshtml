@model IEnumerable<Platforma.Models.Firma>
@{ ViewData["Title"] = "Top Clasament"; int rank = 1; }
<div class="container my-5 text-center">
    <h1 class="mb-5 fw-bold"><i class="fas fa-trophy text-warning me-3"></i>Topul Firmelor</h1>
    <div class="card shadow-lg border-0 mx-auto" style="max-width: 900px;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr><th>Loc</th><th>Nume Firmă</th><th>Categorie</th><th>Rating Mediu</th></tr>
                </thead>
                <tbody>
                    @foreach (var f in Model) {
                        var avg = f.Recenzii.Any() ? f.Recenzii.Average(r => r.Nota) : 0;
                        <tr>
                            <td class="fw-bold fs-5">
                                @if (rank == 1) { <span class="badge bg-warning text-dark">#1</span> }
                                else if (rank == 2) { <span class="badge bg-secondary">#2</span> }
                                else if (rank == 3) { <span class="badge bg-danger">#3</span> }
                                else { <span>#@rank</span> }
                            </td>
                            <td><a asp-controller="Firme" asp-action="Details" asp-route-id="@f.Id" class="text-decoration-none fw-bold text-dark">@f.Nume</a></td>
                            <td><span class="badge bg-light text-dark border">@f.Categorie</span></td>
                            <td class="text-warning fw-bold">
                                @for(int i=0; i<(int)Math.Round(avg); i++) { <i class="fas fa-star"></i> }
                                @for(int i=(int)Math.Round(avg); i<5; i++) { <i class="far fa-star text-muted opacity-25"></i> }
                                <span class="text-muted small ms-2">(@avg.ToString("F1"))</span>
                            </td>
                        </tr>
                        rank++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>