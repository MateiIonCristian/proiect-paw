@model Platforma.Models.Firma

@{
    ViewData["Title"] = "Editeaz„ Firm„";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 bg-white p-4 shadow rounded border-top border-5 border-warning">
            <h3 class="mb-4 text-center fw-bold">Actualizeaz„ Datele Firmei</h3>
            
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                
                <div class="mb-3">
                    <label asp-for="Nume" class="form-label fw-bold">Nume Firm„</label>
                    <input asp-for="Nume" class="form-control" required>
                    <span asp-validation-for="Nume" class="text-danger small"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="Categorie" class="form-label fw-bold">Categorie</label>
                    <input asp-for="Categorie" class="form-control">
                </div>
                
                <div class="mb-3">
                    <label asp-for="Descriere" class="form-label fw-bold">Scurt„ Descriere</label>
                    <textarea asp-for="Descriere" class="form-control" rows="3"></textarea>
                </div>
                
                <div class="mb-3">
                    <label asp-for="Adresa" class="form-label fw-bold">Adres„ (Sediul Central)</label>
                    <input asp-for="Adresa" class="form-control">
                </div>
                
                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary w-50">Anuleaz„</a>
                    <button type="submit" class="btn btn-warning w-50 fw-bold shadow-sm">Salveaz„ Modific„rile</button>
                </div>
            </form>
        </div>
    </div>
</div>
