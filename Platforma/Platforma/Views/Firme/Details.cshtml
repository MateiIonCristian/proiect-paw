@model Platforma.Models.Firma
@{
    ViewData["Title"] = "Detalii Firmă - " + Model.Nume;
    var avg = Model.Recenzii.Any() ? Model.Recenzii.Average(r => r.Nota) : 0;
}
<div class="container my-5">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 sticky-top" style="top: 100px;">
                <div class="card-body text-center">
                    <h2 class="fw-bold text-primary mb-2">@Model.Nume</h2>
                    <p class="badge bg-info text-dark px-3 py-2 mb-3">@(Model.Categorie?.Nume ?? "Fără Categorie")</p>
                    <div class="mb-4">
                        <div class="text-warning mb-1 fs-5">
                            @for(int i=0; i<(int)Math.Round(avg); i++) { <i class="fas fa-star"></i> }
                            @for(int i=(int)Math.Round(avg); i<5; i++) { <i class="far fa-star text-muted opacity-25"></i> }
                            <span class="text-dark fw-bold ms-2">(@avg.ToString("F1"))</span>
                        </div>
                        <small class="text-muted">@Model.Recenzii.Count() recenzii</small>
                    </div>
                    <p class="text-muted small">@Model.Descriere</p>
                    <div class="d-grid gap-2 mt-4">
                        <a asp-action="AddRecenzie" class="btn btn-warning fw-bold shadow-sm">Scrie o Recenzie</a>
                        <a asp-action="Index" class="btn btn-outline-secondary">Înapoi la Catalog</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <h4 class="fw-bold mb-4">Recenziile Clienților</h4>
            @foreach (var rec in Model.Recenzii.OrderByDescending(r => r.DataPublicarii)) {
                <div class="card shadow-sm border-0 mb-3 hover-shadow transition">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="text-warning">
                                @for(int i=0; i<rec.Nota; i++) { <i class="fas fa-star"></i> }
                                @for(int i=rec.Nota; i<5; i++) { <i class="far fa-star text-muted opacity-25"></i> }
                            </div>
                            <small class="text-muted">@rec.DataPublicarii.ToString("dd MMM yyyy")</small>
                        </div>
                        <p class="card-text">@rec.Comentariu</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>