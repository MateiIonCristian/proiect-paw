@model Platforma.Models.Recenzie

@{
    ViewData["Title"] = "Adaug„ Recenzie";
    var firme = ViewBag.Firme as IEnumerable<Platforma.Models.Firma>;
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 bg-white p-4 shadow rounded border-top border-5 border-primary">
            <h3 class="mb-4 text-center fw-bold">Spune-ne p„rerea ta</h3>
            
            @if (firme != null && firme.Any()) {
                <form asp-action="AddRecenzie" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Alege Firma</label>
                        <select name="firmaId" class="form-select border-primary">
                            @foreach (var f in firme) {
                                <option value="@f.Id">@f.Nume (@f.Categorie)</option>
                            }
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nota Ta (1-5)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-warning text-dark"><i class="fas fa-star"></i></span>
                            <input type="number" name="nota" class="form-control" min="1" max="5" value="5" required>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Comentariu</label>
                        <textarea name="comentariu" class="form-control" rows="4" placeholder="Scrie aici experien?a ta..." required></textarea>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold shadow-sm">
                        <i class="fas fa-paper-plane me-2"></i>Posteaz„ Recenzia
                    </button>
                </form>
            } else {
                <div class="alert alert-warning text-center py-4">
                    <i class="fas fa-exclamation-triangle fa-2x mb-3"></i>
                    <p class="mb-3">Nu exist„ nicio firm„ Ónregistrat„ Ón baza de date!</p>
                    <a asp-action="Create" class="btn btn-outline-warning fw-bold">Adaug„ Prima Firm„ Œnt‚i</a>
                </div>
            }
            
            <div class="text-center mt-4">
                <a asp-action="Index" class="text-muted small text-decoration-none">ã Œnapoi la catalog</a>
            </div>
        </div>
    </div>
</div>
